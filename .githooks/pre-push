#!/usr/bin/env sh
set -eu

if [ "${SKIP_PRE_PUSH_VERIFY:-}" = "1" ]; then
  echo "Skipping pre-push verification because SKIP_PRE_PUSH_VERIFY=1."
  exit 0
fi

cd "$(git rev-parse --show-toplevel)"

if command -v python3 >/dev/null 2>&1 && python3 -c "import sys; assert sys.version_info >= (3, 10)" >/dev/null 2>&1; then
  python3 scripts/verify.py --pre-push
elif command -v python >/dev/null 2>&1 && python -c "import sys; assert sys.version_info >= (3, 10)" >/dev/null 2>&1; then
  python scripts/verify.py --pre-push
elif command -v py >/dev/null 2>&1 && py -3 -c "import sys; assert sys.version_info >= (3, 10)" >/dev/null 2>&1; then
  py -3 scripts/verify.py --pre-push
else
  echo "A working Python 3.10+ interpreter is required to run pre-push verification." >&2
  exit 1
fi
